{
  "api": {
    "provider": "openai",
    "model": "gpt-4o",
    "temperature": 0.9,
    "max_tokens": 2048
  },
  "providers": {
    "openai": {
      "base_url": "https://api.openai.com/v1",
      "api_key": ""
    },
    "anthropic": {
      "base_url": "https://api.anthropic.com/v1",
      "api_key": ""
    },
    "google": {
      "base_url": "https://generativelanguage.googleapis.com/v1beta",
      "api_key": ""
    }
  },
  "paths": {
    "wanted": "data/wanted",
    "rejected": "data/rejected",
    "prompts": "data/prompts",
    "exports": "exports"
  },
  "defaults": {
    "prompt_version": "Default",
    "source": "synthetic"
  },
  "server": {
    "host": "127.0.0.1",
    "port": 5000,
    "allowed_ips": [],
    "password": "",
    "allow_local_network": true,
    "trusted_domains": []
  }
}
